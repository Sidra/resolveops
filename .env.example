# ──────────────────────────────────────
# ResolveOps — Environment Variables
# Copy to .env.local and fill in real values
# ──────────────────────────────────────

# Ports
WEB_PORT=3100
API_PORT=3101
WORKER_PORT=3102
WEBHOOK_PORT=3103
POSTGRES_PORT=5436
REDIS_PORT=6380

# Postgres
POSTGRES_DB=resolveops
POSTGRES_USER=resolveops
POSTGRES_PASSWORD=change_me_locally

# Redis
REDIS_URL=redis://localhost:6380

# LLM
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Auth
JWT_SECRET=change_me_to_a_random_32_char_string

# API URL (for frontend)
NEXT_PUBLIC_API_URL=http://localhost:3101
